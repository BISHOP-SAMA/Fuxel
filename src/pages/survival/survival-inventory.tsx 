import { useSurvivalAuth } from "@/hooks/use-survival-auth";
import { useLocation } from "wouter";
import { useEffect } from "react";

export default function SurvivalInventory() {
  const { isAuthenticated, loading } = useSurvivalAuth();
  const [, setLocation] = useLocation();

  useEffect(() => {
    if (!loading && !isAuthenticated) {
      setLocation("/survival/login");
    }
  }, [loading, isAuthenticated, setLocation]);

  if (loading) {
    return (
      <div className="min-h-screen bg-[#0a0800] flex items-center justify-center">
        <div className="text-yellow-600/30 text-2xl animate-pulse">♦</div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-[#0a0800] text-white font-mono">
      <div className="fixed inset-0 pointer-events-none z-0"
        style={{ backgroundImage: 'repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.15) 2px, rgba(0,0,0,0.15) 4px)' }} />
      <div className="relative z-10 max-w-4xl mx-auto px-4 py-20 text-center">
        <div className="text-4xl mb-4">🎒</div>
        <h1 className="text-3xl font-black uppercase mb-4" style={{ fontFamily: 'Georgia, serif', color: '#c8960a' }}>
          Inventory
        </h1>
        <p className="text-gray-500 text-sm">Coming soon. The fox is still packing your gear.</p>
      </div>
    </div>
  );
}
